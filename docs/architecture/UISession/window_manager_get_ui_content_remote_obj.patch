+WSError WindowManagerService::GetUIContentRemoteObj(int32_t persistentId, sptr<IRemoteObject>& uiContentRemoteObj)
+{
+    if (!Permission::IsSystemCalling()) {
+        TLOGE(WmsLogTag::WMS_ATTRIBUTE, "GetUIContentRemoteObj permission denied, persistentId:%{public}d",
+            persistentId);
+        return WSError::WS_ERROR_INVALID_PERMISSION;
+    }
+    auto task = [this, persistentId, &uiContentRemoteObj]() -> WSError {
+        if (windowRoot_ == nullptr) {
+            TLOGE(WmsLogTag::WMS_ATTRIBUTE, "windowRoot_ is null, persistentId:%{public}d", persistentId);
+            return WSError::WS_ERROR_NULLPTR;
+        }
+        sptr<WindowNode> node = windowRoot_->GetWindowNode(static_cast<uint32_t>(persistentId));
+        if (node == nullptr) {
+            TLOGE(WmsLogTag::WMS_ATTRIBUTE, "window node is null, persistentId:%{public}d", persistentId);
+            return WSError::WS_ERROR_INVALID_WINDOW;
+        }
+        sptr<IWindow> windowToken = node->GetWindowToken();
+        if (windowToken == nullptr) {
+            TLOGE(WmsLogTag::WMS_ATTRIBUTE, "window token is null, persistentId:%{public}d", persistentId);
+            return WSError::WS_ERROR_NULLPTR;
+        }
+        WSError errCode = windowToken->GetUIContentRemoteObj(uiContentRemoteObj);
+        TLOGI(WmsLogTag::WMS_ATTRIBUTE,
+            "GetUIContentRemoteObj from app, persistentId:%{public}d, err:%{public}d, remote:%{public}d",
+            persistentId, static_cast<int32_t>(errCode), uiContentRemoteObj != nullptr);
+        if (errCode == WSError::WS_OK && uiContentRemoteObj == nullptr) {
+            return WSError::WS_ERROR_NO_UI_CONTENT_ERROR;
+        }
+        return errCode;
+    };
+    return PostSyncTask(task, "GetUIContentRemoteObj");
+}
