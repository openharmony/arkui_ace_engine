/*
 * Description: WaterFlowз»„д»¶ж”ҜжҢҒеҹәдәҺж–ӯзӮ№иҮӘйҖӮеә”еҲ—ж•°
 * Writer: renxiaowen
 */

import { WaterFlowDataSource } from '../../WaterFlowDataSource';

class waterFlowModifier implements AttributeModifier<WaterFlowAttribute> {
  public index: number = 0;
  public columnList: (string | ItemFillPolicy | undefined | null)[] = [
    '1fr 2fr 1fr',
    { fillType: PresetFillType.BREAKPOINT_DEFAULT },
    { fillType: PresetFillType.BREAKPOINT_SM2MD3LG5 },
    { fillType: PresetFillType.BREAKPOINT_SM1MD2LG3 },
    undefined,
    null
  ]

  applyNormalAttribute(instance: WaterFlowAttribute): void {
    instance.columnsTemplate(this.columnList[this.index])
  }
}

@Entry
@Component
struct WaterFlowDemo {
  @State waterFlowMod: waterFlowModifier = new waterFlowModifier()
  minSize: number = 80;
  maxSize: number = 180;
  colors: number[] = [0xFFC0CB, 0xDA70D6, 0x6B8E23, 0x6A5ACD, 0x00FFFF, 0x00FF7F];
  scroller: Scroller = new Scroller();
  @State contentWidth: number = -1;
  @State contentHeight: number = -1;
  dataSource: WaterFlowDataSource = new WaterFlowDataSource();
  dataCount: number = this.dataSource.totalCount();
  private itemWidthArray: number[] = [];
  private itemHeightArray: number[] = [];
  // еҲҶз»„з®ЎзҗҶпјҡWaterFlowзҡ„ж ёеҝғзү№жҖ§пјҢж”ҜжҢҒдёҚеҗҢеҢәеҹҹдҪҝз”ЁдёҚеҗҢеҲ—ж•°
  @State sections: WaterFlowSections = new WaterFlowSections();
  // еҲҶз»„иҫ№и·қй…ҚзҪ®пјҡз»ҹдёҖзҡ„еӨ–иҫ№и·қи®ҫзҪ®
  sectionMargin: Margin = {
    top: 10,
    left: 5,
    bottom: 10,
    right: 5
  };
  oneColumnSection: SectionOptions = {
    itemsCount: 4, // иҜҘеҲҶз»„еҢ…еҗ«4дёӘFlowItem
    crossCount: 1, // дҪҝз”Ё1еҲ—еёғеұҖ
    // еӣһи°ғеҮҪж•°пјҡеҠЁжҖҒи®ҫзҪ®жҜҸдёӘitemзҡ„й«ҳеәҰ
    onGetItemMainSizeByIndex: (index: number) => {
      return this.itemHeightArray[index % 100];
    }
  };
  // з¬¬дәҢз§ҚеҲҶз»„пјҡеҸҢеҲ—еёғеұҖпјҢйҖӮеҗҲеұ•зӨәеҲ—иЎЁеҶ…е®№
  twoColumnSection: SectionOptions = {
    itemsCount: 2, // иҜҘеҲҶз»„еҢ…еҗ«2дёӘFlowItem
    crossCount: 2, // дҪҝз”Ё2еҲ—еёғеұҖ
    // еӣһи°ғеҮҪж•°пјҡеӣәе®ҡй«ҳеәҰ100px
    onGetItemMainSizeByIndex: (index: number) => {
      return 100;
    }
  };
  // жңҖеҗҺдёҖдёӘеҲҶз»„пјҡз”ЁдәҺеӨ„зҗҶеү©дҪҷж•°жҚ®
  lastSection: SectionOptions = {
    itemsCount: 20, // иҜҘеҲҶз»„еҢ…еҗ«20дёӘFlowItem
    crossCount: 2, // дҪҝз”Ё2еҲ—еёғеұҖ
    // еӣһи°ғеҮҪж•°пјҡдҪҝз”ЁйҡҸжңәй«ҳеәҰ
    onGetItemMainSizeByIndex: (index: number) => {
      return this.itemHeightArray[index % 100];
    }
  };

  // и®Ўз®—FlowItemй«ҳеәҰ
  getSize() {
    let ret = Math.floor(Math.random() * this.maxSize);
    return (ret > this.minSize ? ret : this.minSize);
  }

  // и®ҫзҪ®FlowItemзҡ„й«ҳеәҰж•°з»„
  setItemSizeArray() {
    for (let i = 0; i < 100; i++) {
      this.itemHeightArray.push(100);
    }
  }

  // з»„д»¶з”ҹе‘Ҫе‘ЁжңҹпјҡеҲқе§ӢеҢ–ж•°жҚ®е’ҢжҒўеӨҚдёҠж¬Ўзҡ„еҲ—ж•°и®ҫзҪ®
  aboutToAppear() {
    this.setItemSizeArray();

    // еҲқе§ӢеҢ–зҖ‘еёғжөҒеҲҶз»„дҝЎжҒҜпјҡдәӨжӣҝдҪҝз”ЁеҚ•еҲ—е’ҢеҸҢеҲ—еёғеұҖ
    let sectionOptions: SectionOptions[] = [];
    let count = 0; // е·ІеҲҶй…Қзҡ„FlowItemж•°йҮҸи®Ўж•°
    let oneOrTwo = 0; // з”ЁдәҺдәӨжӣҝйҖүжӢ©еҲҶз»„зұ»еһӢ

    while (count < this.dataCount) {
      // еү©дҪҷж•°жҚ®дёҚи¶і20дёӘж—¶пјҢдҪҝз”ЁжңҖеҗҺдёҖдёӘеҲҶз»„еӨ„зҗҶ
      if (this.dataCount - count < 20) {
        this.lastSection.itemsCount = this.dataCount - count;
        sectionOptions.push(this.lastSection);
        break;
      }

      // дәӨжӣҝдҪҝз”ЁеҚ•еҲ—е’ҢеҸҢеҲ—еёғеұҖ
      if (oneOrTwo++ % 2 == 0) {
        sectionOptions.push(this.oneColumnSection);
        count += this.oneColumnSection.itemsCount;
      } else {
        sectionOptions.push(this.twoColumnSection);
        count += this.twoColumnSection.itemsCount;
      }
    }

    // е°Ҷй…ҚзҪ®еҘҪзҡ„еҲҶз»„ж·»еҠ еҲ°WaterFlowдёӯ
    this.sections.splice(0, 0, sectionOptions);
  }

  build() {
    Column({ space: 2 }) {
      Row() {
        Button('column: ' + this.waterFlowMod.columnList[this.waterFlowMod.index]).onClick(() => {
          this.waterFlowMod.index++;
          this.waterFlowMod.index = this.waterFlowMod.index % this.waterFlowMod.columnList.length;
        })
        Button('splice')
          .height('5%')
          .onClick(() => {
            // йҮҚиҰҒпјҡеҝ…йЎ»дҝқиҜҒLazyForEachдёӯж•°жҚ®ж•°йҮҸе’Ңж–°еҲҶз»„itemsCountзҙҜи®ЎжҖ»ж•°дҝқжҢҒдёҖиҮҙ
            let totalCount: number = this.dataSource.totalCount();
            let newSection: SectionOptions = {
              itemsCount: totalCount,
              crossCount: 2,
              onGetItemMainSizeByIndex: (index: number) => {
                return this.itemHeightArray[index % 100];
              }
            };
            let oldLength: number = this.sections.length();
            this.sections.splice(0, oldLength, [newSection]); // жӣҝжҚўжүҖжңүеҲҶз»„
          })
          .margin({ top: 10, left: 20 })
      }.margin({ bottom: 20 })

      Text('Widthпјҡ' + this.contentWidth + 'пјҢHeightпјҡ' + this.contentHeight)
        .fontColor(Color.Red)
        .height(15)

      WaterFlow({ scroller: this.scroller, layoutMode: WaterFlowLayoutMode.SLIDING_WINDOW, sections: this.sections }) {
        ForEach(this.dataSource.dataArray, (item: number) => {
          FlowItem() {
            // дҪҝз”ЁеҸҜеӨҚз”Ёз»„д»¶пјҢжҸҗеҚҮжҖ§иғҪ
            Column() {
              Text('F' + item).fontSize(12).height('16')
            }
            .height(item * 11)
          }
          .width('100%')
          //.aspectRatio(this.itemHeightArray[item % 100] / this.itemWidthArray[item%100])
          .backgroundColor(this.colors[item % this.colors.length])
        }, (item: string) => item)
      }
      .attributeModifier(this.waterFlowMod)
      .columnsGap(10)
      .backgroundColor(0xFAEEE0)
      .width('100%')
      .height('100%')
      .layoutWeight(1)
    }
  }
}