    "indicator_common/indicator_controller.cpp",
    "indicator_common/indicator_model_ng.cpp",
    "indicator_common/indicator_model_static.cpp",
    "indicator_common/indicator_pattern.cpp",
    "indicator_common/swiper_arrow_layout_algorithm.cpp",
