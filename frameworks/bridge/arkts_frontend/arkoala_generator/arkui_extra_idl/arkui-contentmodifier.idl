package arkui.component.idlize;

[Synthetic]
callback ButtonModifierBuilder = pointer (pointer parentNode, ButtonConfiguration config);
[Synthetic]
callback CheckBoxModifierBuilder = pointer (pointer parentNode, CheckBoxConfiguration config);
[Synthetic]
callback DataPanelModifierBuilder = pointer (pointer parentNode, DataPanelConfiguration config);
[Synthetic]
callback GaugeModifierBuilder = pointer (pointer parentNode, GaugeConfiguration config);
