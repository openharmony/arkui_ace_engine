package arkui.component.idlize;

import arkui.component.units;
import arkui.component.common;
import arkui.Graphics.Frame as Frame;
import global.resource.Resource as Resource; 
import ohos.arkui.observer.default as observer;
import arkui.component.gesture.GestureEvent as GestureEvent;

callback Callback_RangeUpdate = void (i32 start, i32 end, i32 cacheStart, i32 cacheEnd, boolean isLoop);
callback Callback_CreateItem = pointer (i32 index);
callback Callback_OnMoveFromTo = void (i32 from, i32 to);

[Entity=Class]
interface ForEachOps {
    static void SyncOnMoveOps(pointer node, sequence<pointer> additionalChild,
        (OnMoveHandler or undefined) onMoveOps, (ItemDragEventHandler or undefined) onMoveDragEventOps);
};

[Entity=Class]
interface LazyForEachOps {
    // provide necessary info and callbacks to the ScrollView in the backend
    static void NotifyChange(pointer node, i32 startIndex, i32 endIndex, i32 count);
    static void Sync(pointer node, i32 totalCount, Callback_CreateItem creator, Callback_RangeUpdate updater);
    static void SyncOnMoveOps(pointer node, Callback_OnMoveFromTo onMoveFromToOps,
        (OnMoveHandler or undefined) onMoveOps, (ItemDragEventHandler or undefined) onMoveDragEventOps);
};

[Entity=Class]
interface LengthMetricsCustom {
    attribute number unit;
    attribute number value;
};

[Entity=Class]
interface UIContextGetInfo {
    static (observer.NavigationInfo or undefined) getNavigationInfoByUniqueId(i64 id);
    static void enableSwipeBack((boolean or undefined) enabled);
};

callback Callback_Long_Void = void (i64 value);

[Entity=Class]
interface SystemOps {
    static pointer StartFrame();
    static void EndFrame(pointer root);
    static void syncInstanceId(i32 instanceId);
    static void restoreInstanceId();
    static i32 getResourceId(String bundleName, String moduleName, sequence<String> params);
    static void resourceManagerReset();
    static void setFrameCallback(Callback_Long_Void onFrameCallback, Callback_Long_Void onIdleCallback, i64 delayTime);
    static sequence<number> colorMetricsResourceColor(Resource color);
    static sequence<number> blendColorByColorMetrics(number color, number overlayColor);
    static LengthMetricsCustom resourceToLengthMetrics(Resource res);
    static pointer createResourceObject(Resource resource);
};

callback GestureEventHandler = void (GestureEvent event);

[Entity=Class]
interface GestureOps {
    static pointer createTapGesture(number fingers, number count, f64 distanceThreshold, boolean isFingerCountLimited);
    static pointer createLongPressGesture(number fingers, boolean repeat, number duration, boolean isFingerCountLimited);
    static pointer createPanGesture(number fingers, PanDirection direction, number distance, boolean isFingerCountLimited);
    static pointer createPanGestureWithPanGestureOptions(pointer panGestureOptions);
    static pointer createPinchGesture(number fingers, number distance, boolean isFingerCountLimited);
    static pointer createRotationGesture(number fingers, number angle, boolean isFingerCountLimited);
    static pointer createSwipeGesture(number fingers, SwipeDirection direction, number speed, boolean isFingerCountLimited);
    static pointer createGestureGroup(GestureMode mode);
    static void setOnAction(pointer gesture, GestureEventHandler onAction);
    static void setOnActionStart(pointer gesture, GestureEventHandler onActionStart);
    static void setOnActionUpdate(pointer gesture, GestureEventHandler onActionUpdate);
    static void setOnActionEnd(pointer gesture, GestureEventHandler onActionEnd);
    static void setOnActionCancel(pointer gesture, GestureEventHandler onActionCancel);
    static void setOnCancel(pointer gesture, Callback_Void onCancel);
    static void setGestureTag(pointer gesture, String tag);
    static void setAllowedTypes(pointer gesture, sequence<SourceTool> types);
    static void addGestureToNode(pointer node, number priority, GestureMask mask, pointer gesture, boolean isModifier);
    static void addGestureToGroup(pointer group, pointer gesture);
    static void removeGestureByTag(pointer node, String tag);
    static void clearGestures(pointer node);
    static number getGestureEventType(pointer event);
    static boolean isScrollableComponent(pointer event);
};

[Entity=Class]
interface FocusController {
    static void requestFocus(String key);
};

