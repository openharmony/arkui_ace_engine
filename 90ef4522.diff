+        param1.luCorner = { 0.8, 0.0 };//右上 step1
+        param1.ruCorner = { 1.0, 0.0 };
+        param1.lbCorner = { 0.0, 1.0 };
+        param1.rbCorner = { 1.0, 0.2 };
