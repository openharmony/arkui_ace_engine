+void JSViewAbstract::JSDistortionParam(const JSCallbackInfo& info)
+{
+    auto jsVal = info[0];
+    if (!jsVal->IsObject()) {
+        return;
+    }
+    JSRef<JSObject> jsObj = JSRef<JSObject>::Cast(jsVal);
+    DistortionParam param{ .luCorner = NG::VectorF(0,0), .ruCorner = NG::VectorF(0,0), .lbCorner = NG::VectorF(0,0), .rbCorner = NG::VectorF(0,0), .barrelDistortion = NG::Vector4F(0,0,0,0)};
+    ParseDistortionParam(jsObj, param);
+    ViewAbstractModel::GetInstance()->SetDistortionParam(param);
+}
+
+void JSViewAbstract::JSForegroundDistortionParam(const JSCallbackInfo& info)
+{
+    auto jsVal = info[0];
+    if (!jsVal->IsObject()) {
+        return;
+    }
+    JSRef<JSObject> jsObj = JSRef<JSObject>::Cast(jsVal);
+    DistortionParam param{ .luCorner = NG::VectorF(0,0), .ruCorner = NG::VectorF(0,0), .lbCorner = NG::VectorF(0,0), .rbCorner = NG::VectorF(0,0), .barrelDistortion = NG::Vector4F(0,0,0,0)};
+    ParseDistortionParam(jsObj, param);
+    ViewAbstractModel::GetInstance()->SetForegroundFilterDistortionParam(param);
+}
+
+void JSViewAbstract::JSEdgeLightParam(const JSCallbackInfo& info)
+{
+    auto jsVal = info[0];
+    if (!jsVal->IsObject()) {
+        ViewAbstractModel::GetInstance()->SetSDFEdgeLightParam(std::nullopt);
+        return;
+    }
+    JSRef<JSObject> jsObj = JSRef<JSObject>::Cast(jsVal);
+    EdgeLightParam param {
+        .x = 0.0f,
+        .y = 0.0f,
+        .maskWidth = 2.0f,
+        .maskHeight = 0.3f,
+        .angle = -45.0f,
+    };
+    ParseObjParamWithName(jsObj, "x", param.x);
+    ParseObjParamWithName(jsObj, "y", param.y);
+    ParseObjParamWithName(jsObj, "maskWidth", param.maskWidth);
+    ParseObjParamWithName(jsObj, "maskHeight", param.maskHeight);
+    ParseObjParamWithName(jsObj, "angle", param.angle);
+    auto jsParams = jsObj->GetProperty("params");
+    if (jsParams->IsArray()) {
+        JSRef<JSArray> jsArray = JSRef<JSArray>::Cast(jsParams);
+        auto length = jsArray->Length();
+        for (int i = 0; i < length; i++) {
+            auto jsArrayElement = jsArray->GetValueAt(i);
+            double arrValue = 0.0;
+            JSViewAbstract::ParseJsDouble(jsArrayElement, arrValue);
+            param.lightParam.emplace_back(arrValue);
+        }
+    }
+    ViewAbstractModel::GetInstance()->SetSDFEdgeLightParam(param);
+}
