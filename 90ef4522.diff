+bool ParseObjParamWithName(const JSRef<JSObject>& jsObj, const char* name, float& result)
+{
+    auto property = jsObj->GetProperty(name);
+    double res = 0.0;
+    if (JSViewAbstract::ParseJsDouble(property, res)) {
+        result = res;
+        return true;
+    }
+    return false;
+}
+
+void ParseDistortionParam(const JSRef<JSObject>& jsObj, DistortionParam& param)
+{
+    auto shapeVal = jsObj->GetProperty("shape");
+    if (shapeVal->IsObject()) {
+        auto shapeObj = JSRef<JSObject>::Cast(shapeVal);
+        float x = 0.0f;
+        float y = 0.0f;
+        float width = 0.0f;
+        float height = 0.0f;
+        ParseObjParamWithName(shapeObj, "x", x);
+        ParseObjParamWithName(shapeObj, "y", y);
+        ParseObjParamWithName(shapeObj, "width", width);
+        ParseObjParamWithName(shapeObj, "height", height);
+        param.rect = RectF(x, y, width, height);
+    }
+    ParseObjParamWithName(jsObj, "radius", param.radius);
+    auto luCornerVal = jsObj->GetProperty("luCorner");
+    if (luCornerVal->IsObject()) {
+        auto luCornerObj = JSRef<JSObject>::Cast(luCornerVal);
+        ParseObjParamWithName(luCornerObj, "x", param.luCorner.x);
+        ParseObjParamWithName(luCornerObj, "y", param.luCorner.y);
+    }
+    auto ruCornerVal = jsObj->GetProperty("ruCorner");
+    if (ruCornerVal->IsObject()) {
+        auto ruCornerObj = JSRef<JSObject>::Cast(ruCornerVal);
+        ParseObjParamWithName(ruCornerObj, "x", param.ruCorner.x);
+        ParseObjParamWithName(ruCornerObj, "y", param.ruCorner.y);
+    }
+    auto lbCornerVal = jsObj->GetProperty("lbCorner");
+    if (lbCornerVal->IsObject()) {
+        auto lbCornerObj = JSRef<JSObject>::Cast(lbCornerVal);
+        ParseObjParamWithName(lbCornerObj, "x", param.lbCorner.x);
+        ParseObjParamWithName(lbCornerObj, "y", param.lbCorner.y);
+    }
+    auto rbCornerVal = jsObj->GetProperty("rbCorner");
+    if (rbCornerVal->IsObject()) {
+        auto rbCornerObj = JSRef<JSObject>::Cast(rbCornerVal);
+        ParseObjParamWithName(rbCornerObj, "x", param.rbCorner.x);
+        ParseObjParamWithName(rbCornerObj, "y", param.rbCorner.y);
+    }
+    auto distortionVal = jsObj->GetProperty("distortion");
+    if (distortionVal->IsObject()) {
+        auto distortionObj = JSRef<JSObject>::Cast(distortionVal);
+        ParseObjParamWithName(distortionObj, "x", param.barrelDistortion.x);
+        ParseObjParamWithName(distortionObj, "y", param.barrelDistortion.y);
+    }
+}
 } // namespace
 
