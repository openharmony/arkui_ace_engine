import("//build/ohos.gni")
import("//foundation/arkui/ace_engine/ace_config.gni")

_is_preview = use_linux || use_mac || use_mingw_win

config("visualtest_config") {
  include_dirs = [
    "$ace_root",
    "$ace_root/frameworks",
    "$root_out_dir/arkui/framework",
  ]
}

ohos_shared_library("visualtest") {
  sources = [
    "visual_test_napi.cpp",
    "visual_test_impl.cpp",
  ]

  configs = [
    "$ace_root:ace_config",
    ":visualtest_config",
  ]

  defines = [
    # Uncomment to use POSIX open/write/fsync instead of stdio fopen/fwrite:
    # "VISUAL_TEST_FILE_IO_POSIX",
  ]
  deps = []
  external_deps = [ "napi:ace_napi" ]

  if (_is_preview) {
    defines += [ "PREVIEW" ]
    deps += [
      "$ace_root/build:libace_compatible",
      "//third_party/libpng:libpng",
    ]
  } else {
    deps += [ "$ace_root/build:libace_compatible" ]
    external_deps += [ "libpng:libpng" ]
    deps += [ "//foundation/arkui/ace_engine/frameworks/core/components_ng/render:ace_core_components_render_ng_ohos" ]
  }

  if (use_hilog) {
    external_deps += [ "hilog:libhilog" ]
  }

  relative_install_dir = "module/arkui"
  part_name = ace_engine_part
  subsystem_name = ace_engine_subsystem
}
