import("//foundation/arkui/ace_engine/test/unittest/ace_unittest.gni")

ace_unittest("relaxed_interaction_manager_test_ng") {
  module_name = "Pattern-RelaxedInteraction"
  type = "new"
  sources = [
    "$ace_root/interfaces/inner_api/ace/ui_content.cpp",
    "$ace_root/frameworks/core/components_ng/relaxed_interaction/executor_choreographer.cpp",
    "$ace_root/frameworks/core/components_ng/relaxed_interaction/executor_generator.cpp",
    "$ace_root/frameworks/core/components_ng/relaxed_interaction/executors/backpress_executor.cpp",
    "$ace_root/frameworks/core/components_ng/relaxed_interaction/parsers/backpress_command_parser.cpp",
    "$ace_root/frameworks/core/components_ng/relaxed_interaction/relaxed_interaction_manager.cpp",
    "relaxed_interaction_manager_test_ng.cpp",
  ]

  if (!ace_enable_full_test_suite) {
    sources = []
    sources = [ "relaxed_interaction_manager_test_core.cpp" ]
  } else {
    sources += [ "relaxed_interaction_manager_test_core.cpp" ]
  }

  external_deps = [
    "hilog:libhilog"
  ]
}
