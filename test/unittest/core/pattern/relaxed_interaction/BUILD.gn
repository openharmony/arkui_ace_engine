    "$ace_root/frameworks/core/components_ng/relaxed_interaction/executors/fallback_executor.cpp",
    "$ace_root/frameworks/core/components_ng/relaxed_interaction/executors/scroll_simulating_executor.cpp",
    "$ace_root/frameworks/core/components_ng/relaxed_interaction/executors/scroll_touch_executor.cpp",
