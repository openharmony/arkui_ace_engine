import("//build/test.gni")
import("//foundation/arkui/ace_engine/test/unittest/ace_unittest.gni")

ohos_unittest("container_scope_test") {
  module_out_path = frameworks_test_output_path
  sources = [
    "$ace_root/frameworks/core/common/container_scope.cpp",
    "container_scope_test.cpp",
  ]

  configs = [ "$ace_root/test/unittest:ace_unittest_config" ]
}

ohos_unittest("ace_engine_common_test") {
  module_out_path = frameworks_test_output_path
  sources = [
    "$ace_root/frameworks/base/log/dump_log.cpp",
    "$ace_root/frameworks/base/memory/memory_monitor.cpp",
    "$ace_root/frameworks/base/utils/time_util.cpp",
    "$ace_root/frameworks/core/common/ace_engine.cpp",
    "$ace_root/frameworks/core/common/container_scope.cpp",
    "$ace_root/test/mock/frameworks/base/thread/mock_background_task_executor.cpp",
    "$ace_root/test/mock/frameworks/base/utils/mock_lifecycle_checkable.cpp",
    "$ace_root/test/mock/adapter/ohos/osal/mock_system_properties.cpp",
    "$ace_root/test/mock/frameworks/core/common/mock_container.cpp",
    "$ace_root/test/mock/frameworks/core/common/mock_watch_dog.cpp",
    "$ace_root/test/mock/frameworks/core/image/mock_image_cache.cpp",
    "ace_engine_test.cpp",
  ]

  external_deps = [
    "googletest:gmock",
    "googletest:gtest",
  ]

  deps = [ "$ace_root/test/unittest:ace_unittest_log" ]

  configs = [ "$ace_root/test/unittest:ace_unittest_config" ]
}

ace_unittest("color_inverter_test") {
  module_name = "ScrollingSet-Refresh"
  type = "new"

  sources = [ "color_inverter_test.cpp" ]

  if (!ace_enable_full_test_suite) {
    sources = []
    sources = [
      "frameworks_core_common_test_min.cpp",
      "frameworks_core_common_test_core.cpp",
    ]
  } else {
    sources += [
      "frameworks_core_common_test_min.cpp",
      "frameworks_core_common_test_core.cpp",
    ]
  }

  configs = [ "$ace_root/test/unittest:ace_unittest_config" ]
}
