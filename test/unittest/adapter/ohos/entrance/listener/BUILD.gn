import("//foundation/arkui/ace_engine/test/unittest/ace_unittest.gni")

ohos_unittest("ressched_event_listener_test") {
  module_out_path = adapter_test_output_path
  sources = [
    "$ace_root/frameworks/base/utils/string_utils.cpp",
    "$ace_root/adapter/ohos/entrace/ressched_event_listener.cpp",
    "$ace_root/test/mock/frameworks/base/ressched/mock_taihang_optimizer.cpp",
    "$ace_root/test/mock/core/pipeline/mock_pipeline_context.cpp",
    "ressched_event_listener_test.cpp",
  ]

  configs = [ "$ace_root/test/unittest:ace_unittest_config" ]

  external_deps = [
    "googletest:gmock",
    "googletest:gtest",
  ]

  deps = [ 
    "$ace_root/test/unittest:ace_unittest_log",
    "$ace_root/test/mock/ohos_mock/resource_schedule_service:mock_ressched_client",
  ]

  defines = [ "RESOURCE_SCHEDULE_SERVICE_ENABLE" ];
}