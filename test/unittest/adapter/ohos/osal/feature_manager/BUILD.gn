import("//foundation/arkui/ace_engine/test/unittest/ace_unittest.gni")

config("feature_manager_test_config") {
  visibility = [ ":*" ]
  include_dirs = [ "$ace_root/test/mock/frameworks/base/utils" ]
}

ohos_unittest("feature_manager_unittest") {
  module_out_path = adapter_test_output_path
  sources = [
    "$ace_root/adapter/ohos/osal/feature_manager.cpp",
    "$ace_root/frameworks/base/log/log_wrapper.cpp",
    "$ace_root/test/mock/adapter/ohos/osal/mock_system_properties.cpp",
    "$ace_root/test/mock/frameworks/core/common/mock_ace_application_info.cpp",
    "$ace_root/test/mock/frameworks/core/common/mock_extra_modules_manager.cpp",
    "$ace_root/test/mock/frameworks/base/utils/mock_app_space_comp_config_reader.cpp",
    "feature_manager_test.cpp",
  ]

  configs = [
    "$ace_root/test/unittest:ace_unittest_config",
    ":feature_manager_test_config",
  ]

  deps = [ "$ace_root/test/unittest:ace_unittest_log" ]

  external_deps = [
    "googletest:gmock",
    "googletest:gtest_main",
  ]
}
